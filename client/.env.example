# WebSocket signaling server URL. Use wss:// in production.
# Dev default is ws://localhost:3001 if unset.
VITE_SIGNAL_URL=wss://your-signaling-server.example.com

# TURN server for WebRTC NAT traversal. STUN alone fails for ~15-20% of users
# (symmetric NAT, mobile carriers, corporate networks).
# Free options: metered.ca (50GB/mo free), Cloudflare Calls, Open Relay.
# All three vars must be set for TURN to be used.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
